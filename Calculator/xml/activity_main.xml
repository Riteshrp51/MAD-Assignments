<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">

    <!-- Title Text -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculator"
        android:textColor="@color/colorTextWhite"
        android:textSize="22sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Display Area -->
    <LinearLayout
        android:id="@+id/displayArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/iconBar"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/colorTextWhite"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0"
            android:textColor="@color/colorGreen"
            android:textSize="56sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Icon Bar -->
    <LinearLayout
        android:id="@+id/iconBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonGrid">

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_recent_history"
            android:layout_weight="1"
            app:tint="@color/colorTextWhite" />

        <ImageButton
            android:id="@+id/btnScientific"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_compass"
            android:layout_weight="1"
            app:tint="@color/colorTextWhite" />

        <ImageButton
            android:id="@+id/btnUnit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            android:layout_weight="1"
            app:tint="@color/colorTextWhite" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="4" />

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_delete"
            app:tint="@color/colorGreen" />
    </LinearLayout>

    <!-- Buttons Area -->
    <GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:padding="8dp"
        android:rowCount="5"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Row 1 -->
        <Button android:id="@+id/btnAC" style="@style/CalcButton.Dark" android:text="C" />
        <Button android:id="@+id/btnParentheses" style="@style/CalcButton.Dark" android:text="( )" />
        <Button android:id="@+id/btnPercent" style="@style/CalcButton.Dark" android:text="%" />
        <Button android:id="@+id/btnDivide" style="@style/CalcButton.Operator" android:text="÷" />

        <!-- Row 2 -->
        <Button android:id="@+id/btn7" style="@style/CalcButton.Dark" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/CalcButton.Dark" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/CalcButton.Dark" android:text="9" />
        <Button android:id="@+id/btnMultiply" style="@style/CalcButton.Operator" android:text="×" />

        <!-- Row 3 -->
        <Button android:id="@+id/btn4" style="@style/CalcButton.Dark" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/CalcButton.Dark" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/CalcButton.Dark" android:text="6" />
        <Button android:id="@+id/btnSubtract" style="@style/CalcButton.Operator" android:text="-" />

        <!-- Row 4 -->
        <Button android:id="@+id/btn1" style="@style/CalcButton.Dark" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/CalcButton.Dark" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/CalcButton.Dark" android:text="3" />
        <Button android:id="@+id/btnAdd" style="@style/CalcButton.Operator" android:text="+" />

        <!-- Row 5 -->
        <Button android:id="@+id/btnSign" style="@style/CalcButton.Dark" android:text="+/-" />
        <Button android:id="@+id/btn0" style="@style/CalcButton.Dark" android:text="0" />
        <Button android:id="@+id/btnDot" style="@style/CalcButton.Dark" android:text="." />
        <Button android:id="@+id/btnEquals" style="@style/CalcButton.Equals" android:text="=" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>